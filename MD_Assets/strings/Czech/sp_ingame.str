LANG_CZECH        "Pouzije Silu Destrukce."

REFERENCE	    FORCE_DESTRUCTION_DESC
LANG_ENGLISH	    "Force Destruction\nDuration: Instant\nArea of Effect: Projectile\nEffect: Allows Jedi to launch a projectile of force energy.\n\n"
LANG_CZECH        "Zniceni\nTrvani: Okamzity ucinek\nOblast ucinku: Projektil\nUcinek: Umoznuje Jedimu vypustit projektil silove energie.\n\n"

REFERENCE           FORCE_DESTRUCTION_LVL1_DESC
LANG_ENGLISH        "Rank 1 - Jedi launches an orb of force energy."
LANG_CZECH        "Stupen 1 - Jedi vypusti kouli silove energie."

REFERENCE           FORCE_DESTRUCTION_LVL2_DESC
LANG_ENGLISH        "Rank 2 - Jedi launches a more powerful orb of force energy."
LANG_CZECH        "Stupen 2 - Jedi vypusti silnejsi kouli silove energie."

REFERENCE           FORCE_DESTRUCTION_LVL3_DESC
LANG_ENGLISH        "Rank 3 - Jedi launches an extremely dangerous orb of force energy."
LANG_CZECH        "Stupen 3 - Jedi vypusti extremne nebezpecnou kouli silove energie."

