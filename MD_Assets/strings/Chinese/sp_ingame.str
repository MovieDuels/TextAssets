LANG_ENGLISH        "Rank 2 - Jedi launches a more powerful orb of force energy."
LANG_CHINESE        "等级 2 - 绝地发射一个强大的原力能量球。"

REFERENCE           FORCE_DESTRUCTION_LVL3_DESC
LANG_ENGLISH        "Rank 3 - Jedi launches an extremely dangerous orb of force energy."
LANG_CHINESE        "等级 3 - 绝地发射一个极其危险的原力能量球。"

REFERENCE           GRASP
LANG_ENGLISH	    "Grasp:"
LANG_CHINESE        "抓取"

REFERENCE	    GRASP2
LANG_ENGLISH	    "Grasp"
LANG_CHINESE        "抓取"

REFERENCE	    INGAME_GRASP2
LANG_ENGLISH	    "Grasp"
LANG_CHINESE        "抓取"

REFERENCE           FORCE_GRASP_DESC
LANG_ENGLISH        "Force Grasp\nDuration: Instantaneous\nArea Of Effect: Living persons or objects\nEffect: Allows Jedi to hold an enemy or an object with the Force.\n\n"
LANG_CHINESE        "原力抓取\n持续时间：即时\n效果范围：活人或物体\n效果：能让绝地使用原力牵制敌人或物体。\n\n"

REFERENCE           FORCE_GRASP_LVL1_DESC
LANG_ENGLISH        "Rank 1 - Enemy is startled and knocked off balance for 5 seconds."
LANG_CHINESE        "等级 1 - 敌人受到惊吓并失去平衡5秒。"

REFERENCE           FORCE_GRASP_LVL2_DESC
LANG_ENGLISH        "Rank 2 - Jedi lifts their enemy straight off the ground, rendering them defenseless."
LANG_CHINESE        "等级 2 - 绝地将敌人直接抬离地面，使他们毫无防御能力。"

REFERENCE           FORCE_GRASP_LVL3_DESC
LANG_ENGLISH        "Rank 3 - Jedi can freely lift up their enemy and move them around."
LANG_CHINESE        "等级 3 - 绝地武士可以自由地举起敌人并移动他们。"

REFERENCE	    REPULSE
LANG_ENGLISH	    "Repulse:"
LANG_CHINESE        "击退"

REFERENCE	    REPULSE2
LANG_ENGLISH	    "Repulse"
LANG_CHINESE        "击退"

REFERENCE	    INGAME_REPULSE2
LANG_ENGLISH	    "Repulse"
LANG_CHINESE        "击退"

REFERENCE	    USES_REPULSE_FORCE_ABILITY
LANG_ENGLISH	    "Uses Force Repulse ability."
LANG_CHINESE        "使用原力击退能力"

REFERENCE	    FORCE_REPULSE_DESC
LANG_ENGLISH	    "Force Repulse\nDuration: Instant\nArea of Effect: Near Jedi\nEffect: Allows Jedi to push and damage nearby enemies\n\n"
LANG_CHINESE        "原力击退\n持续时间：即时\n效果范围：绝地周围\n效果：能让绝地推动并伤害附近的敌人\n\n"

REFERENCE           FORCE_REPULSE_LVL1_DESC
LANG_ENGLISH        "Rank 1 - Jedi pushes enemies within a small radius. If power is charged, enemies take damage depending on charge time."
LANG_CHINESE        "等级 1 - 绝地将敌人推进一个小半径范围内。如果注能，敌人会根据注能时间受到伤害。"

REFERENCE           FORCE_REPULSE_LVL2_DESC
LANG_ENGLISH        "Rank 2 - Jedi pushes enemies within a medium radius. If power is charged, enemies take damage depending on charge time."
LANG_CHINESE        "等级 2 - 绝地将敌人推进中等半径范围内。如果注能，敌人会根据注能时间受到伤害。"

REFERENCE           FORCE_REPULSE_LVL3_DESC
LANG_ENGLISH        "Rank 3 - Jedi pushes enemies within a large radius. If power is charged, enemies take damage depending on charge time."
LANG_CHINESE        "等级 3 - 地将敌人推进大半径范围内。如果注能，敌人会根据注能时间受到伤害。"

