//-----------------------------------------------------------------------
// NEWGAME MENU
//
//	Called from all other menus other than main menu. This has no transition in it.
//
//-----------------------------------------------------------------------
{						   
	menuDef 
	{
		name					"newgamejkoMenu"
		fullScreen				1						// MENU_TRUE				
		rect					0 0 640 480					// Size and position of the menu
		visible					1						// Visible on open
		focusColor				1 1 1 1			// Focus color for text and items
		descX					320
		descY					426
		descScale				1
		descColor				1 .682 0 .8
		descAlignment			ITEM_ALIGN_CENTER		

		onOpen
		{ 
			setcvar			g_spskill 1
			setcvar			cg_crosshairForceHint 1
			setcvar			handicap 100
			setfocus		medbut
			show			difficulty
			hide			jkonewgame
			exec			"soundstop"
			exec			"music music/mainMenu/sp/JKO_levels_music"
			hide			mainpanelgold
			hide			jkoHTP
            exec            "seta  com_outcast 1" ;
		}

		onESC 
		{ 
			exec			"soundstop"
			play			"sound/interface/esc.wav" 
			exec			"menumusic"
            exec            "seta  com_outcast 0" 
			close			all ; 
			open			mdnewgameMenu 
		}

		//----------------------------------------------------------------------------------------------
		//
		//	MENU BACKGROUND
		//
		//----------------------------------------------------------------------------------------------
	
		itemDef
		{
			name				background_jkoimage
			group				none
			style				WINDOW_STYLE_SHADER
			rect				160 0 640 480
			background			"gfx/menus/main/jkovideobk"
			forecolor			1 1 1 1
			visible				1
			decoration
		}

		itemDef 
		{
			name				background
			group				none
			style				WINDOW_STYLE_SHADER
			rect				0 0 640 480
			background			"gfx/menus/main/jkobk"
			forecolor			1 1 1 1
			visible				1
			decoration
		}
		
		itemDef 
		{
			name				background_logo
			group				none
			style				WINDOW_STYLE_SHADER
			rect				5 51 341.5 115.5
			background			"gfx/menus/main/MDLogo_JK2"
			forecolor			1 1 1 1
			visible				1
			decoration
		}
		
		itemDef 
		{
