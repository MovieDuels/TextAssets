//-----------------------------------------------------------------------
//	CHALLENGE MAPS MENU
//
//	Called only from main menu. Has the transition of fields from main menu 
//	to new game menu
//
//-----------------------------------------------------------------------
{
						   
	menuDef 
	{
		name					"totg_df2Menu"
		fullScreen				1						// MENU_TRUE				
		rect					0 0 640 480					// Size and position of the menu
		visible					1						// Visible on open
		focusColor				1 1 1 1						// Focus color for text and items
		descX					320
		descY					381
		descScale				0.7
		descColor				1 1 1 0.7
		descAlignment				ITEM_ALIGN_CENTER		

		fadeClamp				1.0					// sets the fadeup alpha
		fadeCycle				25					// how often fade happens in milliseconds
		fadeAmount				0.05				// amount to adjust alpha per cycle	

		onOpen
		{ 
				play				"sound/interface/transition.wav" 
				setcvar				g_spskill 1
				setcvar				cg_crosshairForceHint 1
				exec				"set ui_episode_credits df2"
				setitemcolor		black2 backcolor 1 1 1 1
				fadeout				black2
				setitemrect			levelselectholo 640 18 320 480
				setitemcolor		levelselectholo backcolor 1 1 1 0
				setitemcolor		levelselectholo forecolor 1 1 1 0
				fadein				levelselectholo
				setitemcolor		ch1 backcolor 1 1 1 0
				setitemcolor		ch1 forecolor 1 1 1 0
				setitemcolor		newgame backcolor 1 1 1 0
				setitemcolor		newgame forecolor 1 1 1 0
				hide				background_df2bkhol
				hide				df2missionpanels
				hide				df2missionpanelselect
				hide				levelselect
				hide				backbutton
				hide				CycleButtons
				show				background_df2bkkyle
				show				df2panel
				show				df2panel2
				show				df2panel3
				transition			df2panel 322 181 0 60 242 181 160 60 20 20
				transition			df2panel2 322 234 0 60 242 234 160 60 20 20
				transition			df2panel3 322 287 0 60 242 287 160 60 20 20
				delay				500;
				fadein				newgame
		}
									
		onESC 
		{ 
				hide			newgamebackbutton
				hide			df2panelsselect
				setitemrect		black2	0 0 640 480
				play			"sound/interface/esc.wav" 
				close			all ; 
				open			totgMenu
		}


