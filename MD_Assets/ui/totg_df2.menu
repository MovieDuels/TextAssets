		//----------------------------------------------------------------------------------------------
		//
		//   Map List
		//
		//----------------------------------------------------------------------------------------------		

		// Page 1

		itemDef
		{			
			name				ch1
			group				levelselect
			rect				220 403 200 28
			text				@MD_MENU_MAIN_DVL
			type				ITEM_TYPE_BUTTON
			textalign			ITEM_ALIGN_CENTER
			font				5
			textscale			0.19
			textstyle			3
			textaligny			4
			textalignx			100
			forecolor			1 1 1 0.9
			visible				0
			
			mouseEnter 
			{ 
				show			df2missionpanelselect 
			}
			mouseExit
			{
				hide			df2missionpanelselect 
			}
			action
			{
				play			"sound/interface/button1.wav" ; 
				fadein			splash
				delay			800;
				exec			"devmap md_df2_lvl1"
                setcvar         helpusobi 1
                exec            "wait 5"
                setcvar         g_spskill 1
				setcvar			handicap 100
                exec			"setforceall 0"
				exec			"cg_sfxsabers 6"
			}	
		}

		itemDef
		{			
			name				ch2
			group				levelselect
