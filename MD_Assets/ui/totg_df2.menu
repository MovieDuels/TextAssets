		itemDef 
		{
			name				newgamelevelselectbutton
			group				newgame
			text				@MD_MENU_MAIN_LEVEL_SELECT
			type				ITEM_TYPE_BUTTON
			style				WINDOW_STYLE_EMPTY
			rect				248 240 148 43
			textalign			ITEM_ALIGN_CENTER
			font				5
			textscale			0.19
			textstyle			3
			textaligny			12
			textalignx			73
			forecolor			1 1 1 0.9
			visible				1

			mouseEnter
			{
				setitemrect		df2panelsselect	242 234 160 60
				show			df2panelsselect
			}

			mouseExit
			{
				hide			df2panelsselect
			}
			action 
			{ 
				hide			newgame
				hide			df2panels
				hide			df2panelsselect
				hide			background_df2bkkyle	
				fadeout			levelselectholo
				show			background_df2bkhol
				show			df2missionpanels
				transition		df2missionpanels 320 403 0 30 160 403 320 30 20 20
				show			backbutton
				show			PrevButton1
				show			NextButton1
				setitemrect		holo_lvl1 156 18 320 480
				fadein			holo_lvl1
				delay			500;
				fadein			ch1
			} 	  
		}

