		//----------------------------------------------------------------------------------------------
		//
		//   NEW GAME MENU specific stuff
		//
		//----------------------------------------------------------------------------------------------		

		//Arrows In Right Corner

		itemDef 
		{
			name				forward_glow
			group				none
			style				WINDOW_STYLE_SHADER
			rect				0 0 0 0
			background			"gfx/menus/forward_icon_glow"
			forecolor			1 1 1 1
			visible				0
			decoration
		}

		itemDef 
		{
			name				back_glow
			group				none
			style				WINDOW_STYLE_SHADER
			rect				0 0 0 0
			background			"gfx/menus/back_icon_glow"
			forecolor			1 1 1 1
			visible				0
			decoration
		}

		itemDef 
		{
			name				quigonselect
			group				none
			style				WINDOW_STYLE_SHADER
			type				ITEM_TYPE_BUTTON
			rect				25 169 150 150
			background			"gfx/menus/charactericons/qui_robe_icon"
			forecolor			1 1 1 0.8
			visible				1

			mouseEnter 
			{ 
				show			qui_robe_glow
				setitemrect		qui_robe_glow	25 169 150 150
			}

			mouseExit 
			{ 
				hide			qui_robe_glow
			}	 
 	  
			action 
			{ 
				play			"sound/interface/button1.wav" ; 
				hide			description ;
				hide			obiwanselect ; 
				hide			rightarrow ; 
				hide			leftarrow ; 
				hide			backbutton ; 
				show			background2 ; 
				show			diff_light ;
				show			backbutton2 ; 
				show			qui_robe_icon_diff ;
				exec			"set ui_mission_credits_music ep1SNj"
			}
		}

		itemDef 
		{
			name				obiwanselect
			group				none
			style				WINDOW_STYLE_SHADER
			type				ITEM_TYPE_BUTTON
			rect				465 169 150 150
			background			"gfx/menus/charactericons/obi1_robe_icon"
			forecolor			1 1 1 0.8
			visible				1

			mouseEnter 
			{ 
				show			obi1_robe_glow
				setitemrect		obi1_robe_glow	465 169 150 150
			}

			mouseExit 
			{ 
				hide			obi1_robe_glow
			}	 
 	  
			action 
			{ 
				play			"sound/interface/button1.wav" ; 
				hide			description ; 
				hide			quigonselect ; 
				hide			rightarrow ; 
				hide			leftarrow ; 
				hide			backbutton ; 
				show			background2 ; 
				show			diff_light2 ;
				show			backbutton2 ; 
				show			obi1_robe_icon_diff ;
				exec			"set ui_mission_credits_music ep1SNj"
			}
		}

