//-----------------------------------------------------------------------
//	CHARACTERSELECT MENU
//
//	Called only from main menu. Has the transition of fields from main menu 
//	to new game menu
//
//-----------------------------------------------------------------------
{
						   
	menuDef 
	{
		name					"snMenu"
		fullScreen				1						// MENU_TRUE				
		rect					0 0 640 480					// Size and position of the menu
		visible					1						// Visible on open
		focusColor				1 1 1 1						// Focus color for text and items
		descX					320
		descY					426
		descScale				1
		descColor				1 .682 0 .8
		descAlignment				ITEM_ALIGN_CENTER		

		onOpen
		{ 
				setcvar			g_spskill 1
				setcvar			cg_crosshairForceHint 1
				setcvar			handicap 100
		}
									
		onESC 
		{ 
			play				"sound/interface/esc.wav" 
			show				description ; 
			show				quigonselect ;
			show				obiwanselect ;  
			show				rightarrow ; 
			show				leftarrow ; 
			show				backbutton ; 
			hide				background2 ;  
			hide				diff_light ;
			hide				diff_light2 ;
			hide				backbutton2 ; 
			hide				qui_robe_icon_diff ;
			hide				obi1_robe_icon_diff ;
			close				all
			open				episode1Menu
		}

		//----------------------------------------------------------------------------------------------
		//
		//	MENU BACKGROUND
		//
		//----------------------------------------------------------------------------------------------
		
		itemDef 
		{
			name				background
			group				none
			style				WINDOW_STYLE_SHADER
			rect				0 0 640 480
			background			"gfx/menus/mission/ep1/episode1_sn"
			forecolor			1 1 1 1
			visible				1
			decoration
		}
		
		itemDef 
		{
			name				description
			group				none
			style				WINDOW_STYLE_FILLED
			background			"gfx/menus/mission/desc_panel"
			rect				184.5 95.25 271 360.5
			backcolor			1 1 1 1
			visible				1
			decoration
		}
		
		itemDef
		{
			name				description
			type				ITEM_TYPE_TEXT
			rect				189 132 260 26
			text				@MD_MENU_MAIN_SN
			font				5
			forecolor			1 1 1 1
			textscale			0.245
			textalign			ITEM_ALIGN_CENTER
			textalignx			131
			textaligny			1
			visible				1
			decoration
		}
		
		itemDef
		{
			name				description
			type				ITEM_TYPE_TEXTSCROLL
			rect				190 170 283 255
			text				@MD_BRIEFINGS_EP1_SN_DESC
			font				5
			forecolor			1 1 1 1
			textscale			0.14
			textalign			ITEM_ALIGN_CENTER
			textalignx			1
			textaligny			0
			lineHeight			13
			visible				1
			autowrapped
			decoration
		}
		
		itemDef 
		{
			name				background_logo
			group				logo
			style				WINDOW_STYLE_FILLED
			background			"gfx/menus/mission/ep1/Ep1Logo"
			rect				199 24 246 82
			backcolor			1 1 1 1
			visible				1
			decoration
		}

