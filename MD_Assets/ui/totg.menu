			{
				"0"
			}	

 			mouseEnter
			{
				transition			InfoBox	100 125 0 28 100 125 180 28 10 10
				fadein				TFUText
				setitemrect			mapTopL -36 -9 320 240
				fadein				mapTopL
				setitembackground	TFUIcon "gfx/menus/totg/TFU_Icon2"
				transition2			TFUIcon	78.5 116 36 48 10 10
			}
			mouseExit
			{
				transition2			InfoBox 100 125 0 28 10 10
				setitemcolor		TFUText backcolor 1 1 1 0
				setitemcolor		TFUText forecolor 1 1 1 0
				hide				TFUText
				fadeout				mapTopL
				setitembackground	TFUIcon "gfx/menus/totg/TFU_Icon1"
				transition2			TFUIcon	80 118 33 44 10 10
			}
			action 
			{ 
				transition2			InfoBox 100 125 0 28 10 10
				setitemcolor		TFUText backcolor 1 1 1 0
				setitemcolor		TFUText forecolor 1 1 1 0
				hide				TFUText
				fadeout				mapTopL
				setitembackground	TFUIcon "gfx/menus/totg/TFU_Icon1"
				transition2			TFUIcon	80 118 33 44 10 10

				play				"sound/md_ch/sta1.mp3" ;
				hide				mapButtons
				fadeout				mapTopL
				setitemrect			mapTopLA -36 -9 320 240
				fadein				mapTopLA
				delay				1700 ;
				fadein				black
				delay				800 ;
				setitemcolor		mapTopLA backcolor 1 1 1 0
				setitemcolor		black backcolor 1 1 1 1
				fadeout				black
				exec				"soundstop"
				exec				"music music/md_tfu/md_tfu"
				close				all ; 
				open				totg_tfuMenu 
			}
		}

