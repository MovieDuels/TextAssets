		itemDef 
		{
			name				welcomeButton
			group				welcome
			text				@MD_MENU_MAIN_CONTINUE
			type				ITEM_TYPE_BUTTON
			style				WINDOW_STYLE_FILLED
			rect				275 378 90 24  
			font				5
			textscale			0.14
			textalign			ITEM_ALIGN_CENTER
			textalignx			45
			textaligny			4
			forecolor			1 1 1 0.9
			backcolor			0 0 0 0
