//----------------------------------------------------------------------------------------------
//
// TOTG MENU
//
//----------------------------------------------------------------------------------------------
						   
	menuDef 
	{
		name					"totgMenu"
		fullScreen					1		
		rect					0 0 640 480	
		visible					1
		focusColor					1 1 1 1
		descX					320
		descY					426
		descScale					1
		descColor					1 .682 0 .8
		descAlignment				ITEM_ALIGN_CENTER	

		fadeClamp				1.0					// sets the fadeup alpha
		fadeCycle				25					// how often fade happens in milliseconds
		fadeAmount				0.05				// amount to adjust alpha per cycle	

		onOpen 
		{
			exec				"cl_noprint 1"
			exec				"exec TOTG_DF2_Addon"
			exec				"cl_noprint 0"
			exec				"soundstop"
			exec				"totgmapmusic"
			setitemcolor		mapText backcolor 1 1 1 0
			setitemcolor		mapText forecolor 1 1 1 0
			hide				mapText
			show				mapIcons
			show				mapButtons
			hide				mapButtonsErrors
			setitemcolor		KelDorInfo backcolor 1 1 1 0
			setitemcolor		KelDorInfo forecolor 1 1 1 0
			hide				KelDorInfo
			hide				KelDorText
			hide				KelDorButton

			transition			TFUIcon	96.5 140 0 0 80 118 33 44 20 20
			transition			ROTEIcon 306.5 348 0 0 290 326 33 44 20 20
			transition			S1Icon 450.5 226 0 0 434 204 33 44 20 20
			transition			S2Icon 445.5 112 0 0 429 90 33 44 20 20
			transition			S3Icon 296.5 45 0 0 280 23 33 44 20 20
			transition			UnknownIcon 289.5 172 0 0 273 150 33 44 20 20
		}							
		onESC 
		{ 
			//exec				"soundstop"
			//play				"sound/interface/esc.wav" 
			//exec				"menumusic" 
			//show				fadeenterbutton
			//close				all ; 
			//open				mdnewgameMenu ;
		}

