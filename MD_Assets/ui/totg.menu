		// Fix pop in when entering the menu the first time (using OnOpen leads to other pop ins)

		itemDef 
		{
			name				fadeenterbutton
			group				none
			style				WINDOW_STYLE_FILLED
			rect				56 349 240 24
			forecolor			1 1 1 0
			visible				1
			decoration

			mouseEnter
			{
				setitemrect			mapParts 641 0 640 480
				fadeout				mapParts
				hide				fadeenterbutton
				show				splash
				setitemcolor		splash backcolor 1 1 1 1
				hide				mapText
				hide				mapIcons
				hide				mapButtons
				delay				1000 ;
				fadeout				splash
				delay				500 ;

				show				mapIcons
				show				mapButtons
				transition			TFUIcon	96.5 140 0 0 80 118 33 44 20 20
				transition			ROTEIcon 306.5 348 0 0 290 326 33 44 20 20
				transition			S1Icon 450.5 226 0 0 434 204 33 44 20 20
				transition			S2Icon 445.5 112 0 0 429 90 33 44 20 20
				transition			S3Icon 296.5 45 0 0 280 23 33 44 20 20
				transition			UnknownIcon 289.5 172 0 0 273 150 33 44 20 20
			}
			mouseExit
			{
			}
			action 
			{ 
			}
		}

