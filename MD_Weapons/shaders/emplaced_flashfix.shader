gfx/effects/emplacedSideFlash
{
	cull	twosided
    {
        map gfx/effects/emplacedsideflash
        blendFunc GL_ONE GL_ONE
        rgbGen vertex
    }
}

gfx/effects/emplacedFrontFlash
{
	cull	twosided
    {
        map gfx/effects/emplacedfrontflash
        blendFunc GL_ONE GL_ONE
        rgbGen vertex
    }
}