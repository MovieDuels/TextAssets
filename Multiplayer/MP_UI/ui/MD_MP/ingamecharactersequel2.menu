		//------------------------
		//  	Moff Gideon
		//------------------------	

		itemDef 
		{
			name				challenge_begin3
			group				iconsSEQUELpage
			style				WINDOW_STYLE_SHADER
			type				ITEM_TYPE_BUTTON
			rect				134 110 85 85
			background			"gfx/menus/charactericons/gideon_icon"
			forecolor			1 1 1 0.8
			visible				1
			descText			@MD_MENU_CHARS_GIDEON

			mouseEnter 
			{ 
				show			gideon_glow
				setitemrect		gideon_glow	134 110 85 85
			}

			mouseExit 
			{ 
				hide			gideon_glow
			}	 
 	  
			action 
			{ 
				play			"sound/chars/finn/gideon/taunt4.mp3" ; 
				close			all ; 
				exec			"model gideon"
			}
		}

