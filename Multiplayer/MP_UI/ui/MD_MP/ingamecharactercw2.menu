		//------------------------
		//  Darth Sidious TCW
		//------------------------

		itemDef 
		{
			name				challenge_begin3
			group				iconsCW2page
			style				WINDOW_STYLE_SHADER
			type				ITEM_TYPE_BUTTON
			rect				38 158 85 85
			background			"gfx/menus/charactericons/sid_tcw_icon"
			forecolor			1 1 1 0.8
			visible				1
			descText			@MD_MENU_CHARS_SIDIOUS_TCW

			mouseEnter 
			{ 
				show			sid_tcw_glow
				setitemrect		sid_tcw_glow	38 158 85 85
			}

			mouseExit 
			{ 
				hide			sid_tcw_glow
			}	 
 	  
			action 
			{ 
				play			"sound/chars/palpatine_sith/misc/gloat3.mp3" ;
				exec			"model palpatine/robed_tcw"
				close			all ; open ingame_saber3
			}
		}
		
