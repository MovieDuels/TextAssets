		//------------------------	

		itemDef 
		{
			name				yoda_icon_main
			group				iconsPREQUEL1page
			style				WINDOW_STYLE_SHADER
			type				ITEM_TYPE_BUTTON
			rect				38 110 85 85
			background			"gfx/menus/charactericons/yod3_icon"
			forecolor			1 1 1 0.8
			visible				1
			descText			@MD_MENU_CHARS_YODA

			mouseEnter 
			{ 
				show			yod3_glow
				setitemrect		yod3_glow	38 110 85 85
			}

			mouseExit 
			{ 
				hide			yod3_glow
			}	 
 	  
			action 
			{  
				hide 			iconsPREQUEL1page ;
				show 			subIconsBackButton ;
				hide			yod3_glow ;
				show			yoda 	
			}
		}

