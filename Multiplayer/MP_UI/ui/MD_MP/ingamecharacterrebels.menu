		{
			name				background
			group				none
			style				WINDOW_STYLE_SHADER
			rect				0 0 640 480
			background			"gfx/menus/ingame/characternpcspawn/background_reb"
			forecolor			1 1 1 1
			visible				1
			decoration
		}
		
