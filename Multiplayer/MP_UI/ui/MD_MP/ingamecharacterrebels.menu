		//     Kanan Jarrus
		//------------------------	

		itemDef 
		{
			name				challenge_begin2
			group				iconsREBELSpage
			style				WINDOW_STYLE_SHADER
			type				ITEM_TYPE_BUTTON
			rect				38 158 85 85
			background			"gfx/menus/charactericons/kan_icon"
			forecolor			1 1 1 0.8
			visible				1
			descText			@MD_MENU_CHARS_KANAN

			mouseEnter 
			{ 
				show			kan_glow
				setitemrect		kan_glow	 38 158 85 85
			}

			mouseExit 
			{ 
				hide			kan_glow
			}	 
 	  
			action 
			{ 
				hide 			iconsREBELSpage ;
				show 			subIconsBackButton ;
				hide			kan_glow ;
				show			kanan 	
			}
		}

