		//------------------------	

		itemDef 
		{
			name				sidious_icon_main
			group				iconsPREQUEL3page
			style				WINDOW_STYLE_SHADER
			type				ITEM_TYPE_BUTTON
			rect				38 110 85 85
			background			"gfx/menus/charactericons/sid3_icon"
			forecolor			1 1 1 0.8
			visible				1
			descText			@MD_MENU_CHARS_SIDIOUS

			mouseEnter 
			{ 
				show			sid3_glow
				setitemrect		sid3_glow	38 110 85 85
			}

			mouseExit 
			{ 
				hide			sid3_glow
			}	 
 	  
			action 
			{  
				hide 			iconsPREQUEL3page ;
				show 			subIconsBackButton ;
				hide			sid3_glow ;
				show			sidious 	
			}
		}

