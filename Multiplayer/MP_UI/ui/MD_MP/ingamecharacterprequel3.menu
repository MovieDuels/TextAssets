//----------------------------------------------------------------------------------------------
//
//	PREQUEL3 CHARACTERS MENU
//
//----------------------------------------------------------------------------------------------
{
	menuDef
	{
		name					"ingamecharacterprequel3Menu"
		fullScreen				1									// MENU_TRUE
		rect					0 0 640 480							// Size and position of the menu
		focusColor				1 1 1 1				// Focus color for text and items
		descX					320
		descY					440
		descScale				0.7
		descColor				1 1 1 0.9
		descAlignment			ITEM_ALIGN_CENTER
		visible					0								// Visible on open

		fadeClamp				1.0						// sets the fadeup alpha
		fadeCycle				10						// how often fade happens in milliseconds
		fadeAmount				0.1					// amount to adjust alpha per cycle

		onOpen
		{
			setfocus			resume ;
			hide				glowicons
		}

		onESC
		{
			play				"sound/interface/esc.wav" 
			close				all
			open				ingamecharactereraMenu
			show 			iconsPREQUEL3page ;
			hide 			subIconsBackButton ;
			hide 			sidious ;
			hide 			anis ; 
			hide 			maul ; 
			hide 			grievous ; 
			hide 			jango ; 
			hide			neimoidian ;
			hide			tusken ;
			hide			battledroid ;
		}

