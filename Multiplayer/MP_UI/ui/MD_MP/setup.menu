				hide			video2 ;
				hide			vidrestart	;
			    show			renderer	;
				hide			sound	;
				hide			options ;
				hide			defaults ;
				hide			advanced ;

				setitemcolor	setup_submenu		forecolor	1 .682 0 1 ;
				setitemcolor	Renderermenubutton	forecolor	1 1 1 1 ;
			}
		}

