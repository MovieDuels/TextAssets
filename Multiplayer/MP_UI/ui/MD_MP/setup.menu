			type				ITEM_TYPE_BUTTON
			style				WINDOW_STYLE_EMPTY
			rect				80 233 170 24
			font				3
			textscale			0.9
			textalignx			160
			textaligny			2
			textalign			ITEM_ALIGN_RIGHT
			textstyle			0
			forecolor			1 .682 0 1
			visible			    1
			descText			"Set Advanced Renderer settings."
			cvarTest			"cl_renderer"
			hideCvar			{ "MovieDuels-rdmp" }

