		// HILT BUTTON 2 - DUAL
		itemDef 
		{
			name				hiltbut2
			group				none

			rect				240 165 160 54
			type				ITEM_TYPE_LISTBOX
			style				WINDOW_STYLE_EMPTY
			elementwidth 			120
