			textalignx			0
			textaligny			0
			font 				4
			textscale 			1
			forecolor			.615 .615 .956 1
			visible			0
			//descText			"Select a Lightsaber blade type"

			action
			{
				play			"sound/interface/button1.wav"
			}
		}
		itemDef 
		{
			name				rgbsetupbutton
			group				none
			text				@MENUS_LIGHTSABER_CREATION
			descText			"RGB Saber Color"
			type				ITEM_TYPE_BUTTON
			style				WINDOW_STYLE_EMPTY
			rect				100 54 440 16
			font				3
			textscale			0.7
			textstyle			0
			textalign			ITEM_ALIGN_CENTER		
			textalignx			225
			textaligny			-1
			forecolor			.549 .854 1 1
			visible			1
			mouseEnter 
			{ 
				setitemcolor		rgbsetupbutton forecolor 1 1 1 1
				setitemcolor		rgbsetupbutton bordercolor .66 .66 1 1
			}
			mouseExit 
			{ 
				setitemcolor		rgbsetupbutton forecolor .549 .854 1 1
				setitemcolor		rgbsetupbutton bordercolor .33 .33 .5 1
			}	  	  
			action 
			{
				play			"sound/interface/choose_blade.wav"
				hide 			typebut
				hide 			typebut_single
				hide 			typebut_dual
				hide 			typebut_staff
				hide 			hilttype
				hide			hiltbut
				hide			hiltbut1
				hide			hiltbut2
				hide			hiltbut_staves
				hide			box1
				hide 			box3top
				hide 			box3middle
				hide 			box3bottom
				hide 			sabericons
				hide 			sabericons2
				hide			newgame_begin
			        hide 			exitgamebutton
			        hide 			rgbsetupbutton
                                hide 			sfxblade
				show 			rgboptions
				setcvar 		ui_saber_color	 "rgb"
				setcvar 		ui_saber2_color	 "rgb"

			}
		}
		
		itemDef 
		{
			name				rgbsetupapply
			group				rgboptions
			text				"@MENUS_APPLY"
			descText			"Apply these settings to your RGB saber blades and close the window."
			type				ITEM_TYPE_BUTTON
			style				WINDOW_STYLE_EMPTY
			rect				255 444 130 24 
			font				3
			textscale			1
			textalignx			65
			textaligny			-1
			textalign			ITEM_ALIGN_CENTER
			textstyle			3
			forecolor			1 .682 0 1
			visible				1
			mouseEnter 
			{ 
				setitemcolor		rgbsetupapply forecolor 1 1 1 1
				setitemcolor		rgbsetupapply bordercolor .66 .66 1 1
			}
			mouseExit 
			{ 
				setitemcolor		rgbsetupapply forecolor .549 .854 1 1
				setitemcolor		rgbsetupapply bordercolor .33 .33 .5 1
			}	  	  
			action 
			{
				play			"sound/interface/choose_blade.wav"
				show 			typebut
				show 			typebut_single
				show 			typebut_dual
				show 			typebut_staff
				show 			hilttype
				show			hiltbut
				show			hiltbut1
				show			hiltbut2
				show 			hiltbut_staves
				show			box1
				show 			box3top
				show 			box3middle
				show 			box3bottom
				show 			sabericons
				show 			sabericons2
