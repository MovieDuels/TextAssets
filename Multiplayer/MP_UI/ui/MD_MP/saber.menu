			group				none
			text				@MENUS_APPLY
			descText			@MENUS_APPLY_SABER_CHANGES
			type				ITEM_TYPE_BUTTON
			style				WINDOW_STYLE_EMPTY
			rect				455 444 130 24 
			font				3
			textscale			1
			textalignx			65
			textaligny			-1
			textalign			ITEM_ALIGN_CENTER
			textstyle			3
			forecolor			1 .682 0 1
			visible				1
	      	action 
			{ 
				uiScript 		"updatesabercvars"
				uiScript  		"saber_color"
				uiScript  		"saber2_color"
				close			sabermenu
				open			main
			}
			mouseEnter 
			{ 
				show			begingamebutton_glow
			}
			mouseExit 
			{ 
				hide			begingamebutton_glow
			}	  	  
		}
	}
}
