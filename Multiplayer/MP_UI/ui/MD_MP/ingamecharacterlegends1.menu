		{
			name				kyle_icon_main
			group				iconsLEGENDS1page
			style				WINDOW_STYLE_SHADER
			type				ITEM_TYPE_BUTTON
			rect				38 110 85 85
			background			"gfx/menus/charactericons/kyle_icon"
			forecolor			1 1 1 0.8
			visible				1
			descText			@MD_MENU_CHARS_KYLE

			mouseEnter 
			{ 
				show			kyle_glow
				setitemrect		kyle_glow	38 110 85 85
			}

			mouseExit 
			{ 
				hide			kyle_glow
			}	 
 	  
			action 
			{  
				hide 			iconsLEGENDS1page ;
				show 			subIconsBackButton ;
				hide			kyle_glow ;
				show			kyle	
			}
		}

