		{
			name				ben_icon_main
			group				iconsOTpage
			style				WINDOW_STYLE_SHADER
			type				ITEM_TYPE_BUTTON
			rect				38 110 85 85
			background			"gfx/menus/charactericons/ben_icon"
			forecolor			1 1 1 0.8
			visible				1
			descText			@MD_MENU_CHARS_BEN

			mouseEnter 
			{ 
				show			ben_glow
				setitemrect		ben_glow	38 110 85 85
			}

